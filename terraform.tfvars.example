# ============================================================================
# Payment Form Infrastructure - Terraform Variables Example
# ============================================================================
# Copy this file to terraform.tfvars and fill in your actual values
# Or use environment-specific files in infrastructure/environments/
# ============================================================================

# ----------------------------------------------------------------------------
# Core Configuration
# ----------------------------------------------------------------------------
project_name = "paymentform"
environment  = "sandbox"  # Options: dev, sandbox, prod
region       = "us-east-1"

# ----------------------------------------------------------------------------
# Domain Configuration
# ----------------------------------------------------------------------------
domain_name        = "paymentform.io"
api_subdomain      = "api.sandbox.paymentform.io"
app_subdomain      = "app.sandbox.paymentform.io"
renderer_subdomain = "*.sandbox.paymentform.io"

# ----------------------------------------------------------------------------
# Database Credentials (Required - Sensitive!)
# ----------------------------------------------------------------------------
neon_database_url = "postgresql://user:password@host.neon.tech/dbname"
turso_api_token   = "your_turso_api_token"

# ----------------------------------------------------------------------------
# Cloudflare Configuration
# ----------------------------------------------------------------------------
cloudflare_api_email  = "your@email.com"
cloudflare_api_token  = "YOUR_CLOUDFLARE_API_TOKEN"
cloudflare_zone_id    = "YOUR_ZONE_ID"
cloudflare_account_id = "YOUR_ACCOUNT_ID"

# ----------------------------------------------------------------------------
# Cloudflare Containers Configuration (NEW - replaces Amplify & EC2 Renderer)
# ----------------------------------------------------------------------------
enable_cloudflare_containers = true

# Client container (Next.js standalone SSR build)
client_container_image = "ghcr.io/your-org/paymentform-client:latest"
client_container_env_vars = {
  NEXT_PUBLIC_API_URL = "https://api.sandbox.paymentform.io"
  NODE_ENV            = "production"
}

# Renderer container (Next.js + Caddy for wildcard TLS)
renderer_container_image = "ghcr.io/your-org/paymentform-renderer:latest"
renderer_container_env_vars = {
  NEXT_PUBLIC_API_URL = "https://api.sandbox.paymentform.io"
  NODE_ENV            = "production"
}

# Container resource allocation
container_deployment_cpu       = "0.5"
container_deployment_memory_mb = 512
container_instance_min_count   = 1

# ----------------------------------------------------------------------------
# R2 Storage Configuration
# ----------------------------------------------------------------------------
r2_bucket_name = "paymentform-uploads"

# SSL config bucket for Caddy certificates (renderer container)
r2_ssl_bucket_name       = "paymentform-ssl-config"
r2_ssl_access_key_id     = "YOUR_R2_SSL_ACCESS_KEY"
r2_ssl_secret_access_key = "YOUR_R2_SSL_SECRET_KEY"

# Worker for public file serving (optional)
worker_enabled       = true
worker_route_pattern = "cdn.sandbox.paymentform.io/*"

# ----------------------------------------------------------------------------
# KV Store Configuration
# ----------------------------------------------------------------------------
kv_store_api_token = "YOUR_KV_STORE_API_TOKEN"

# ----------------------------------------------------------------------------
# AWS Configuration (Backend EC2 only)
# ----------------------------------------------------------------------------
backend_instance_type    = "t4g.micro"
backend_desired_capacity = 1
backend_ami_id           = "" # Leave empty to use default

# GHCR token for pulling container images
ghcr_token = "ghp_YOUR_GITHUB_TOKEN"

# ----------------------------------------------------------------------------
# Application Secrets (Stored in AWS SSM)
# ----------------------------------------------------------------------------
app_key                      = "your_laravel_app_key"
db_password                  = "your_db_password"
pgadmin_default_password     = "your_pgadmin_password"
tenant_db_auth_token         = "your_tenant_db_jwt"
tenant_db_encryption_key     = "your_encryption_key"
mail_password                = "your_smtp_password"
aws_access_key_id            = "YOUR_AWS_ACCESS_KEY"
aws_secret_access_key        = "YOUR_AWS_SECRET_KEY"
google_client_secret         = "your_google_oauth_secret"
stripe_secret                = "sk_test_your_stripe_secret"
stripe_client_id             = "ca_your_stripe_client_id"
stripe_connect_webhook_secret = "whsec_your_webhook_secret"
turso_auth_token             = "your_turso_auth_token"
redis_password               = "your_redis_password"

# ----------------------------------------------------------------------------
# Legacy AWS Amplify Configuration (DEPRECATED - use Cloudflare Containers)
# ----------------------------------------------------------------------------
enable_amplify = false

# If using Amplify (not recommended):
# renderer_repository_url = "https://github.com/your-org/renderer"
# renderer_branch_name    = "main"
# client_repository_url   = "https://github.com/your-org/client"
# client_branch_name      = "main"
# amplify_access_token    = "ghp_YOUR_TOKEN"

# ----------------------------------------------------------------------------
# Monitoring & Backup
# ----------------------------------------------------------------------------
enable_monitoring = true
enable_backup     = true

# ----------------------------------------------------------------------------
# Resource Tagging
# ----------------------------------------------------------------------------
common_tags = {
  Environment = "sandbox"
  Terraform   = "true"
  ManagedBy   = "opentofu"
  CostCenter  = "development"
}

cost_center = "development"
owner       = "devops-team"
managed_by  = "opentofu"

# ----------------------------------------------------------------------------
# Cost Optimization Notes
# ----------------------------------------------------------------------------
# Cloudflare Containers: ~$10-15/month (vs $30-50 for EC2 renderer)
# Cloudflare Pages: Free tier available (vs $0-25 for Amplify)
# R2 SSL Storage: <$1/month
#
# Total Savings: ~$20-40/month compared to AWS Amplify + EC2 renderer
#
# Quick Start:
#   1. Copy this file: cp terraform.tfvars.example terraform.tfvars
#   2. Set your secrets and container images
#   3. Run: tofu init && tofu plan && tofu apply
#
# ============================================================================
