# Terraform/OpenTofu
.terraform/
*.tfstate
*.tfstate.backup
.terraform.lock.hcl

# Plan files (may contain sensitive data)
tfplan*
*.tfplan

# Override files (local development)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash logs
crash.log
crash.*.log

# Ignore root-level terraform.tfvars (if used for secrets)
/terraform.tfvars

# Local environment files
.env
.env.local

# Wrangler configuration (may contain sensitive account IDs)
wrangler.toml
wrangler.json

# Output files
outputs.json
*-outputs.json
terraform.tfvars
.envrc
tofu.plan
.infracost/
cost-estimate*
