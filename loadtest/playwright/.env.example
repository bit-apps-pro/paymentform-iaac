# Copy to .env and fill in. dotenv is loaded by playwright.config.ts.

# Host suffix shared by api.*, app.*, mailpit.*, and <tenant>.*
TRAEFIK_HOST=paymentform.btcd-test.io

# Traefik http port (matches docker-compose.dev-local.yml TRAEFIK_PORT)
TRAEFIK_PORT=8021

# How many browser contexts run in parallel.
WORKERS=5

# Per-worker iteration count. Each iteration runs the full signup->submit chain.
ITERATIONS=1

# Stripe TEST-MODE login credentials for the Connect OAuth flow. Use a dedicated
# Stripe test account; the flow drives the real Stripe OAuth UI in headed mode.
STRIPE_TEST_EMAIL=
STRIPE_TEST_PASSWORD=

# Optional: pin the registration password (default is generated per worker).
# REGISTRATION_PASSWORD=Loadtest-Pa55!

# Optional: cap the verification-code wait. Default 60s.
# MAILPIT_TIMEOUT_MS=60000

# Optional: cap the workspace-status poll wait. Default 180s.
# WORKSPACE_TIMEOUT_MS=180000
