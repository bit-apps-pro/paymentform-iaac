# Backend Environment Configuration
# Generated by Ansible for {{ environment }} environment

NODE_ENV={{ environment }}
PORT={{ backend_port | default(3000) }}

# Database URLs (from Terraform outputs)
DATABASE_URL={{ neon_connection_string }}
TENANT_DB_URL={{ turso_tenant_url }}
ANALYTICS_DB_URL={{ turso_analytics_url }}

# API Configuration
API_URL=https://{{ api_subdomain }}
APP_URL=https://{{ app_subdomain }}
RENDERER_URL=https://{{ renderer_subdomain | replace('*', '{tenant}') }}

# AWS Configuration
AWS_REGION={{ aws_region }}
AWS_S3_BUCKET={{ s3_bucket_name | default('') }}

# Security
JWT_SECRET={{ jwt_secret | default('change-me-in-production') }}
CORS_ORIGINS={{ app_subdomain }},{{ renderer_subdomain }}

# Logging
LOG_LEVEL={{ 'debug' if enable_debug_logging else 'info' }}
